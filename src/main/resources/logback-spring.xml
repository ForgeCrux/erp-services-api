<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
        Generated logging baseline.
        Console output is intentionally the default for Cloud Run and container platforms.
        File output is attached programmatically by LoggingConfig when
        app.logging.destination=FILE or CONSOLE_AND_FILE.
    -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
